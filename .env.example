EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: enables address autocomplete on customer/property address
# fields (Places API (New)). Without it, those fields fall back to plain
# text inputs with no autocomplete or lat/lng lookup. See README for setup.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key
